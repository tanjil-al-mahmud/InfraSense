[Unit]
Description=InfraSense Notification Service
After=network.target postgresql.service

[Service]
Type=simple
User=infrasense
Group=infrasense
ExecStart=/usr/local/bin/infrasense-notification-service
EnvironmentFile=-/etc/infrasense/infrasense-notification-service.env
Restart=always
RestartSec=10s
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
