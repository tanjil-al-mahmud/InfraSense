[Unit]
Description=InfraSense SNMP Collector
After=network.target postgresql.service

[Service]
Type=simple
User=infrasense
Group=infrasense
ExecStart=/usr/local/bin/infrasense-snmp-collector
EnvironmentFile=-/etc/infrasense/infrasense-snmp-collector.env
Restart=always
RestartSec=10s
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
