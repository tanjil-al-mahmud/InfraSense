#!/bin/bash
set -e

#DEBHELPER#

case "$1" in
    purge)
        # Remove configuration files and data directories
        rm -rf /etc/infrasense
        rm -rf /var/lib/infrasense
        rm -rf /var/log/infrasense

        # Remove infrasense system user and group
        if getent passwd infrasense > /dev/null 2>&1; then
            userdel infrasense || true
        fi

        if getent group infrasense > /dev/null 2>&1; then
            groupdel infrasense || true
        fi

        echo "InfraSense Platform has been completely removed."
    ;;

    remove|upgrade|failed-upgrade|abort-install|abort-upgrade|disappear)
        # Keep configuration and data on remove/upgrade
    ;;

    *)
        echo "postrm called with unknown argument: '$1'" >&2
        exit 1
    ;;
esac

exit 0
